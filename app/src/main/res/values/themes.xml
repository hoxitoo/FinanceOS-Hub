<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash screen theme — background matches app Background color -->
    <style name="Theme.FinanceOSHub" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0D12</item>
        <item name="postSplashScreenTheme">@style/Theme.FinanceOSHub.Main</item>
    </style>

    <!-- Parent must be an AppCompat descendant: MainActivity is an AppCompatActivity
         (needed for the biometric FragmentActivity host). A framework Material theme
         crashes at startup with "You need to use a Theme.AppCompat theme". -->
    <style name="Theme.FinanceOSHub.Main" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#0A0D12</item>
        <item name="android:statusBarColor">#0A0D12</item>
        <item name="android:navigationBarColor">#111620</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
