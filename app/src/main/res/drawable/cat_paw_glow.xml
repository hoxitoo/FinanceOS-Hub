<?xml version="1.0" encoding="utf-8"?>
<!-- Cat paw print — proper anatomy: one large metacarpal pad at the bottom and four toe beans
     in an arc above it. Solid violet fill; on-screen fade is applied at draw time in
     PawParticleLayer (the fill stays opaque so the alpha isn't double-attenuated). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="64dp"
    android:height="64dp"
    android:viewportWidth="64"
    android:viewportHeight="64">

    <!-- Metacarpal pad (bottom-centre, largest) -->
    <path
        android:fillColor="#9B5CFF"
        android:pathData="M18,44 a14,11 0 1,0 28,0 a14,11 0 1,0 -28,0 z" />

    <!-- Toe — outer left -->
    <path
        android:fillColor="#9B5CFF"
        android:pathData="M8,28 a6,7.5 0 1,0 12,0 a6,7.5 0 1,0 -12,0 z" />

    <!-- Toe — inner left -->
    <path
        android:fillColor="#9B5CFF"
        android:pathData="M17.5,17 a6.5,8.5 0 1,0 13,0 a6.5,8.5 0 1,0 -13,0 z" />

    <!-- Toe — inner right -->
    <path
        android:fillColor="#9B5CFF"
        android:pathData="M33.5,17 a6.5,8.5 0 1,0 13,0 a6.5,8.5 0 1,0 -13,0 z" />

    <!-- Toe — outer right -->
    <path
        android:fillColor="#9B5CFF"
        android:pathData="M44,28 a6,7.5 0 1,0 12,0 a6,7.5 0 1,0 -12,0 z" />
</vector>
